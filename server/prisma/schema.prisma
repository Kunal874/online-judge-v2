// Prisma schema — grows incrementally as each milestone needs new models.
// See the project plan for the full intended shape (Problem/TestCase/Submission
// land in later milestones).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  handle        String   @unique
  name          String
  role          Role     @default(USER)
  emailVerified Boolean  @default(false)

  // Hashed the same way passwordHash is — a DB leak shouldn't hand out usable tokens.
  emailVerifyTokenHash String?   @unique
  emailVerifyExpires   DateTime?
  resetTokenHash       String?   @unique
  resetTokenExpires    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions Submission[]

  @@index([email])
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id            String     @id @default(cuid())
  slug          String     @unique
  title         String
  statement     String
  difficulty    Difficulty
  tags          String[]
  constraints   String?
  timeLimitMs   Int        @default(2000)
  memoryLimitKb Int        @default(262144)
  isPublished   Boolean    @default(false)
  contestId     String? // reserved for a future Contest relation, unused for now

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  testCases   TestCase[]
  submissions Submission[]

  @@index([difficulty])
  @@index([tags], type: Gin)
}

// isHidden:false rows ARE the "sample test cases" shown on the problem
// page — no separate sampleTestCases table needed, one model covers both.
model TestCase {
  id             String  @id @default(cuid())
  problemId      String
  problem        Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input          String
  expectedOutput String
  isHidden       Boolean @default(true)
  orderIndex     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results TestCaseResult[]

  @@index([problemId])
}

enum Language {
  CPP
  C
  JAVA
  PYTHON
}

enum Verdict {
  PENDING
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  INTERNAL_ERROR
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  language  Language
  code      String
  verdict   Verdict  @default(PENDING)

  // Truncated compiler/internal error only — never a raw stack trace.
  errorMessage String?
  runtimeMs    Int? // max across test cases
  memoryKb     Int? // max across test cases
  passedCount  Int  @default(0)
  totalCount   Int  @default(0)
  contestId    String? // reserved for a future Contest relation, unused for now

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results TestCaseResult[]

  @@index([userId, createdAt])
  @@index([userId, problemId])
}

// Deliberately has no input/expectedOutput/actualOutput fields — only
// pass/fail + index + resource usage, so this table structurally cannot
// leak hidden test case content regardless of who queries it.
model TestCaseResult {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCaseId   String
  testCase     TestCase   @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  orderIndex   Int
  verdict      Verdict
  runtimeMs    Int?
  memoryKb     Int?

  @@index([submissionId])
}
