// Prisma schema — grows incrementally as each milestone needs new models.
// See the project plan for the full intended shape (Problem/TestCase/Submission
// land in later milestones).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  handle        String   @unique
  name          String
  role          Role     @default(USER)
  emailVerified Boolean  @default(false)

  // Hashed the same way passwordHash is — a DB leak shouldn't hand out usable tokens.
  emailVerifyTokenHash String?   @unique
  emailVerifyExpires   DateTime?
  resetTokenHash       String?   @unique
  resetTokenExpires    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id            String     @id @default(cuid())
  slug          String     @unique
  title         String
  statement     String
  difficulty    Difficulty
  tags          String[]
  constraints   String?
  timeLimitMs   Int        @default(2000)
  memoryLimitKb Int        @default(262144)
  isPublished   Boolean    @default(false)
  contestId     String? // reserved for a future Contest relation, unused for now

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([difficulty])
  @@index([tags], type: Gin)
}
