{
  "name": "@online-judge/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "typecheck": "tsc --noEmit",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "docker:build": "docker build -t online-judge-python:latest -f docker/python.Dockerfile docker && docker build -t online-judge-gcc:latest -f docker/gcc.Dockerfile docker && docker build -t online-judge-java:latest -f docker/java.Dockerfile docker"
  },
  "dependencies": {
    "@online-judge/shared": "*",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.81.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dockerode": "^5.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
