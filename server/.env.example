PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://judge:devpassword@localhost:5433/online_judge
# Generate your own with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_random_64+_char_string
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=2
# Leave unset for local dev — an Ethereal test account is created
# automatically (nothing is really delivered, previews are logged to the
# console). Set these once you have a real SMTP provider.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
